<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MLSanity — Compare report</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; color: #1f2937; }
    h1 { margin: 0 0 6px; }
    .muted { color: #6b7280; margin: 0 0 20px; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; margin-bottom: 20px; }
    .card { border: 1px solid #e5e7eb; border-radius: 8px; padding: 12px; }
    .label { font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; }
    .value { font-size: 22px; font-weight: 600; margin-top: 6px; }
    table { border-collapse: collapse; width: 100%; margin-top: 12px; }
    th, td { border: 1px solid #e5e7eb; padding: 8px 10px; text-align: left; }
    th { background: #f9fafb; }
    .ok { color: #15803d; font-weight: 600; }
    .warning { color: #b45309; font-weight: 600; }
    .error { color: #b91c1c; font-weight: 600; }
  </style>
</head>
<body>
  <h1>MLSanity compare report</h1>
  <p class="muted">{{ report.old_path }} → {{ report.new_path }}</p>

  <div class="cards">
    <div class="card">
      <div class="label">Dataset type</div>
      <div class="value">{{ report.dataset_type }}</div>
    </div>
    <div class="card">
      <div class="label">Sample delta</div>
      <div class="value">{{ report.total_samples_delta }}</div>
    </div>
    <div class="card">
      <div class="label">Health delta</div>
      <div class="value">{{ report.health_score_delta }}</div>
    </div>
  </div>

  <h2>Class distribution (old vs new)</h2>
  <table>
    <thead>
      <tr>
        <th>Class</th>
        <th>Old count</th>
        <th>New count</th>
        <th>Delta</th>
      </tr>
    </thead>
    <tbody>
      {% for item in report.new_class_counts|dictsort %}
      <tr>
        <td>{{ item[0] }}</td>
        <td>{{ report.old_class_counts[item[0]] if report.old_class_counts[item[0]] is defined else 0 }}</td>
        <td>{{ item[1] }}</td>
        <td>{{ item[1] - (report.old_class_counts[item[0]] if report.old_class_counts[item[0]] is defined else 0) }}</td>
      </tr>
      {% endfor %}
      {% for item in report.old_class_counts|dictsort %}
      {% if report.new_class_counts[item[0]] is not defined %}
      <tr>
        <td>{{ item[0] }}</td>
        <td>{{ item[1] }}</td>
        <td>0</td>
        <td>{{ 0 - item[1] }}</td>
      </tr>
      {% endif %}
      {% endfor %}
    </tbody>
  </table>

  <h2>Check deltas</h2>
  <table>
    <thead>
      <tr>
        <th>Check</th>
        <th>Old status</th>
        <th>New status</th>
        <th>Old issues</th>
        <th>New issues</th>
        <th>Delta</th>
      </tr>
    </thead>
    <tbody>
      {% for d in report.check_deltas %}
      <tr>
        <td>{{ d.name }}</td>
        <td class="{{ d.old_status }}">{{ d.old_status }}</td>
        <td class="{{ d.new_status }}">{{ d.new_status }}</td>
        <td>{{ d.old_issue_count }}</td>
        <td>{{ d.new_issue_count }}</td>
        <td>{{ d.issue_delta }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>Regressions and resolutions</h2>
  <p><strong>Introduced:</strong> {{ report.introduced_regressions | join(", ") if report.introduced_regressions else "none" }}</p>
  <p><strong>Resolved:</strong> {{ report.resolved_issues | join(", ") if report.resolved_issues else "none" }}</p>
</body>
</html>
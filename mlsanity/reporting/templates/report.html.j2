<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MLSanity — Dataset report</title>
  <style>
    :root {
      --bg: #0b1020;
      --panel: #12192b;
      --panel-2: #0f1727;
      --panel-3: #0c1422;
      --line: rgba(148, 163, 184, 0.16);
      --line-strong: rgba(148, 163, 184, 0.28);
      --text: #e7edf7;
      --muted: #94a3b8;
      --ok: #34d399;
      --warn: #fbbf24;
      --err: #f87171;
      --accent: #60a5fa;
      --accent-2: #818cf8;
      --shadow: 0 10px 26px rgba(2, 6, 23, 0.26);
      --radius: 12px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(96, 165, 250, 0.08), transparent 20%),
        linear-gradient(180deg, #0a1020 0%, #0b1020 100%);
      color: var(--text);
      font-size: 14px;
      line-height: 1.45;
    }

    .page {
      max-width: 1160px;
      margin: 0 auto;
      padding: 18px 16px 28px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .title h1 {
      margin: 0;
      font-size: 1.22rem;
      letter-spacing: -0.03em;
      font-weight: 700;
    }

    .title p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.82rem;
    }

    .anchors {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .anchors a {
      color: var(--muted);
      text-decoration: none;
      padding: 6px 10px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255,255,255,0.02);
      font-size: 0.76rem;
    }

    .anchors a:hover {
      color: var(--text);
      border-color: var(--line-strong);
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 12px;
      margin-bottom: 12px;
    }

    @media (max-width: 920px) {
      .summary-grid { grid-template-columns: 1fr; }
    }

    .card,
    details.section,
    details.check {
      background: linear-gradient(180deg, var(--panel) 0%, var(--panel-2) 100%);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .card-body {
      padding: 14px;
    }

    .overview {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 16px;
      align-items: center;
    }

    @media (max-width: 720px) {
      .overview { grid-template-columns: 1fr; }
    }

    .ring-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .ring {
      --pct: {{ report.health_score }};
      width: 132px;
      height: 132px;
      min-width: 132px;
      min-height: 132px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle closest-side, var(--panel-2) 66%, transparent 67% 100%),
        conic-gradient(
          {% if report.overall_status == 'healthy' %}var(--ok)
          {% elif report.overall_status == 'acceptable' %}var(--accent)
          {% elif report.overall_status == 'needs_attention' %}var(--warn)
          {% else %}var(--err)
          {% endif %} calc(var(--pct) * 1%),
          rgba(148, 163, 184, 0.16) 0
        );
      border: 1px solid var(--line);
      flex: 0 0 auto;
    }

    .ring .inner {
      width: 82px;
      height: 82px;
      border-radius: 50%;
      background: var(--panel-2);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ring .score {
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .ring-label {
      color: var(--muted);
      font-size: 0.68rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .meta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    @media (max-width: 720px) {
      .meta { grid-template-columns: 1fr; }
    }

    .meta-item,
    .mini {
      padding: 10px;
      border-radius: 10px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--line);
    }

    .meta-item .k,
    .mini .k,
    .detail-box .label {
      color: var(--muted);
      font-size: 0.64rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 5px;
    }

    .meta-item .v {
      font-size: 0.88rem;
      font-weight: 600;
      word-break: break-word;
    }

    .tiny-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 8px;
      margin-top: 10px;
    }

    @media (max-width: 900px) {
      .tiny-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }

    @media (max-width: 600px) {
      .tiny-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    .mini .v {
      font-size: 0.9rem;
      font-weight: 700;
    }

    .status-healthy { color: var(--ok); }
    .status-acceptable { color: var(--accent); }
    .status-needs_attention { color: var(--warn); }
    .status-critical { color: var(--err); }

    details.section,
    details.check {
      overflow: hidden;
    }

    details.section + details.section,
    details.check + details.check {
      margin-top: 10px;
    }

    summary.section-head,
    summary.check-head {
      list-style: none;
      cursor: pointer;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto auto;
      gap: 10px;
      align-items: center;
      padding: 12px 14px;
    }

    summary.section-head::-webkit-details-marker,
    summary.check-head::-webkit-details-marker {
      display: none;
    }

    .head-title {
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .head-sub {
      margin-top: 2px;
      color: var(--muted);
      font-size: 0.77rem;
    }

    .count {
      color: var(--muted);
      font-size: 0.73rem;
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.02);
    }

    .chev {
      color: var(--muted);
      font-size: 0.88rem;
      transition: transform 0.18s ease;
    }

    details[open] > summary .chev {
      transform: rotate(180deg);
    }

    .section-body,
    .check-body {
      padding: 0 14px 14px;
      border-top: 1px solid var(--line);
      background: rgba(255,255,255,0.012);
    }

    .priority-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-top: 12px;
    }

    .priority-item {
      padding: 11px 12px;
      border-radius: 10px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--line);
      border-left: 4px solid rgba(148, 163, 184, 0.24);
    }

    .priority-item.warning { border-left-color: var(--warn); }
    .priority-item.error { border-left-color: var(--err); }

    .priority-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 4px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border: 1px solid transparent;
    }

    .badge-ok { background: rgba(52, 211, 153, 0.12); color: var(--ok); border-color: rgba(52, 211, 153, 0.22); }
    .badge-warning { background: rgba(251, 191, 36, 0.12); color: var(--warn); border-color: rgba(251, 191, 36, 0.22); }
    .badge-error { background: rgba(248, 113, 113, 0.12); color: var(--err); border-color: rgba(248, 113, 113, 0.22); }

    .muted {
      color: var(--muted);
      font-size: 0.78rem;
    }

    .suggest {
      margin: 7px 0 0 1rem;
      color: var(--muted);
      font-size: 0.78rem;
      padding: 0;
    }

    .suggest li + li { margin-top: 4px; }

    .checks-wrap {
      padding-top: 12px;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      margin-top: 10px;
    }

    @media (max-width: 760px) {
      .detail-grid { grid-template-columns: 1fr; }
      summary.section-head,
      summary.check-head { grid-template-columns: minmax(0, 1fr) auto; }
      .chev { display: none; }
    }

    .detail-box {
      padding: 10px;
      border-radius: 10px;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--line);
    }

    .detail-box .value {
      font-size: 0.8rem;
      word-break: break-word;
    }

    .code-wrap {
      position: relative;
      margin-top: 7px;
    }

    .copy-btn {
      position: absolute;
      top: 8px;
      right: 8px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      color: var(--muted);
      border-radius: 8px;
      font-size: 0.68rem;
      padding: 4px 8px;
      cursor: pointer;
      transition: 0.18s ease;
      z-index: 2;
    }

    .copy-btn:hover {
      color: var(--text);
      border-color: var(--line-strong);
      background: rgba(255,255,255,0.08);
    }

    .code-block {
      margin-top: 7px;
      padding: 10px;
      padding-top: 34px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: rgba(2, 6, 23, 0.28);
      color: #dbe6f5;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 0.73rem;
      line-height: 1.45;
      white-space: pre-wrap;
      word-break: break-word;
      overflow-wrap: anywhere;
      max-height: 220px;
      overflow: auto;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 7px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 0.72rem;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      color: var(--text);
    }

    .table-wrap {
      overflow: auto;
      margin-top: 10px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: rgba(255,255,255,0.02);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 620px;
      background: transparent;
    }

    th, td {
      text-align: left;
      padding: 9px 10px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      vertical-align: top;
      font-size: 0.78rem;
    }

    th {
      color: var(--muted);
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      background: rgba(255,255,255,0.03);
      position: sticky;
      top: 0;
    }

    tr:last-child td { border-bottom: 0; }

    .graph-wrap {
      padding-top: 12px;
    }

    .graph-title {
      color: var(--muted);
      font-size: 0.77rem;
      margin-bottom: 10px;
    }

    .dist-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .view-toggle {
      display: inline-flex;
      gap: 6px;
      padding: 4px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255,255,255,0.02);
    }

    .view-toggle button {
      border: 0;
      background: transparent;
      color: var(--muted);
      font-size: 0.72rem;
      padding: 6px 10px;
      border-radius: 999px;
      cursor: pointer;
      transition: 0.18s ease;
    }

    .view-toggle button.active {
      background: rgba(96, 165, 250, 0.16);
      color: var(--text);
    }

    .class-view,
    .split-view {
      display: none;
    }

    .class-view.active,
    .split-view.active {
      display: block;
    }

    .svg-card {
      border: 1px solid var(--line);
      border-radius: 10px;
      background: rgba(255,255,255,0.02);
      padding: 12px;
      overflow: auto;
    }

    .chart-scroller {
      overflow-x: auto;
      overflow-y: hidden;
      padding-bottom: 6px;
    }

    .chart-svg {
      display: block;
      height: 340px;
    }

    footer {
      margin-top: 18px;
      text-align: center;
      color: var(--muted);
      font-size: 0.74rem;
    }
  </style>
</head>

<script>
  function setDistributionView(mode) {
    const classGraphView = document.getElementById("classGraphView");
    const classJsonView = document.getElementById("classJsonView");
    const splitGraphView = document.getElementById("splitGraphView");
    const splitJsonView = document.getElementById("splitJsonView");

    const graphBtns = document.querySelectorAll(".distribution-graph-btn");
    const jsonBtns = document.querySelectorAll(".distribution-json-btn");

    if (mode === "json") {
      if (classGraphView) classGraphView.classList.remove("active");
      if (classJsonView) classJsonView.classList.add("active");
      if (splitGraphView) splitGraphView.classList.remove("active");
      if (splitJsonView) splitJsonView.classList.add("active");

      graphBtns.forEach(btn => btn.classList.remove("active"));
      jsonBtns.forEach(btn => btn.classList.add("active"));
    } else {
      if (classJsonView) classJsonView.classList.remove("active");
      if (classGraphView) classGraphView.classList.add("active");
      if (splitJsonView) splitJsonView.classList.remove("active");
      if (splitGraphView) splitGraphView.classList.add("active");

      jsonBtns.forEach(btn => btn.classList.remove("active"));
      graphBtns.forEach(btn => btn.classList.add("active"));
    }
  }

  async function copyCode(button) {
    const wrap = button.closest(".code-wrap");
    if (!wrap) return;
    const code = wrap.querySelector(".code-block");
    if (!code) return;

    const text = code.innerText;
    try {
      await navigator.clipboard.writeText(text);
      const old = button.innerText;
      button.innerText = "Copied";
      setTimeout(() => {
        button.innerText = old;
      }, 1200);
    } catch (e) {
      button.innerText = "Failed";
      setTimeout(() => {
        button.innerText = "Copy";
      }, 1200);
    }
  }
</script>

<body>
  <div class="page">
    <div class="topbar">
      <div class="title">
        <h1>MLSanity dataset report</h1>
        <p>Minimal, dense, and readable. Built to show findings clearly without dashboard clutter.</p>
      </div>
      <div class="anchors">
        <a href="#overview">Overview</a>
        <a href="#distributions">Distributions</a>
        <a href="#priorities">Priorities</a>
        <a href="#checks">Checks</a>
      </div>
    </div>

    {% set ns = namespace(ok=0, warning=0, error=0) %}
    {% for c in report.checks %}
      {% if c.status == 'ok' %}
        {% set ns.ok = ns.ok + 1 %}
      {% elif c.status == 'warning' %}
        {% set ns.warning = ns.warning + 1 %}
      {% elif c.status == 'error' %}
        {% set ns.error = ns.error + 1 %}
      {% endif %}
    {% endfor %}

    <div class="summary-grid" id="overview">
      <div class="card">
        <div class="card-body">
          <div class="overview">
            <div class="ring-wrap">
              <div class="ring" aria-label="Health score gauge" role="img">
                <div class="inner">
                  <span class="score status-{{ report.overall_status }}">{{ report.health_score }}</span>
                </div>
              </div>
              <div class="ring-label">Health score</div>
            </div>
            <div>
              <div class="meta">
                <div class="meta-item">
                  <div class="k">Dataset type</div>
                  <div class="v">{{ report.dataset_type }}</div>
                </div>
                <div class="meta-item">
                  <div class="k">Total samples</div>
                  <div class="v">{{ report.total_samples }}</div>
                </div>
                <div class="meta-item">
                  <div class="k">Overall status</div>
                  <div class="v status-{{ report.overall_status }}">{{ report.overall_status }}</div>
                </div>
                <div class="meta-item">
                  <div class="k">Checks</div>
                  <div class="v">{{ report.checks | length }}</div>
                </div>
                {% if report.dataset_path %}
                <div class="meta-item" style="grid-column: 1 / -1;">
                  <div class="k">Dataset path</div>
                  <div class="v muted">{{ report.dataset_path }}</div>
                </div>
                {% endif %}
              </div>

              <div class="tiny-grid">
                <div class="mini">
                  <div class="k">Passed</div>
                  <div class="v">{{ ns.ok }}</div>
                </div>
                <div class="mini">
                  <div class="k">Warnings</div>
                  <div class="v status-needs_attention">{{ ns.warning }}</div>
                </div>
                <div class="mini">
                  <div class="k">Errors</div>
                  <div class="v status-critical">{{ ns.error }}</div>
                </div>
                <div class="mini">
                  <div class="k">Issue rate</div>
                  <div class="v">
                    {% if report.checks|length > 0 %}
                      {{ (((ns.warning + ns.error) / (report.checks|length)) * 100) | round(0) }}%
                    {% else %}
                      0%
                    {% endif %}
                  </div>
                </div>
                <div class="mini">
                  <div class="k">Pass rate</div>
                  <div class="v">
                    {% if report.checks|length > 0 %}
                      {{ ((ns.ok / (report.checks|length)) * 100) | round(0) }}%
                    {% else %}
                      100%
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <div class="graph-wrap">
            <div class="graph-title">Issue distribution</div>
            <div class="svg-card">
              {% set total_checks = report.checks|length if report.checks|length > 0 else 1 %}
              <svg viewBox="0 0 520 230" width="100%" height="auto" role="img" aria-label="Issue distribution graph">
                <defs>
                  <linearGradient id="okGradient" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#34d399"></stop>
                    <stop offset="100%" stop-color="#10b981"></stop>
                  </linearGradient>
                  <linearGradient id="warnGradient" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#fbbf24"></stop>
                    <stop offset="100%" stop-color="#f59e0b"></stop>
                  </linearGradient>
                  <linearGradient id="errGradient" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="#f87171"></stop>
                    <stop offset="100%" stop-color="#ef4444"></stop>
                  </linearGradient>
                </defs>

                <line x1="52" y1="180" x2="490" y2="180" stroke="rgba(148,163,184,0.16)" stroke-width="1" />
                <line x1="52" y1="130" x2="490" y2="130" stroke="rgba(148,163,184,0.08)" stroke-width="1" />
                <line x1="52" y1="80" x2="490" y2="80" stroke="rgba(148,163,184,0.08)" stroke-width="1" />
                <line x1="52" y1="30" x2="490" y2="30" stroke="rgba(148,163,184,0.08)" stroke-width="1" />

                {% set max_issue = [ns.ok, ns.warning, ns.error, 1] | max %}
                {% set h_ok = (ns.ok / max_issue) * 130 %}
                {% set h_warn = (ns.warning / max_issue) * 130 %}
                {% set h_err = (ns.error / max_issue) * 130 %}

                <rect x="100" y="{{ 180 - h_ok }}" width="70" height="{{ h_ok }}" rx="8" fill="url(#okGradient)"></rect>
                <rect x="225" y="{{ 180 - h_warn }}" width="70" height="{{ h_warn }}" rx="8" fill="url(#warnGradient)"></rect>
                <rect x="350" y="{{ 180 - h_err }}" width="70" height="{{ h_err }}" rx="8" fill="url(#errGradient)"></rect>

                <text x="135" y="{{ 172 - h_ok }}" text-anchor="middle" fill="#e7edf7" font-size="13" font-family="Inter, sans-serif" font-weight="700">{{ ns.ok }}</text>
                <text x="260" y="{{ 172 - h_warn }}" text-anchor="middle" fill="#e7edf7" font-size="13" font-family="Inter, sans-serif" font-weight="700">{{ ns.warning }}</text>
                <text x="385" y="{{ 172 - h_err }}" text-anchor="middle" fill="#e7edf7" font-size="13" font-family="Inter, sans-serif" font-weight="700">{{ ns.error }}</text>

                <text x="135" y="205" text-anchor="middle" fill="#94a3b8" font-size="12" font-family="Inter, sans-serif">OK</text>
                <text x="260" y="205" text-anchor="middle" fill="#94a3b8" font-size="12" font-family="Inter, sans-serif">Warnings</text>
                <text x="385" y="205" text-anchor="middle" fill="#94a3b8" font-size="12" font-family="Inter, sans-serif">Errors</text>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <details class="section" id="distributions" open>
      <summary class="section-head">
        <div>
          <div class="head-title">Distributions</div>
          <div class="head-sub">Class, split, and issue summaries</div>
        </div>
        <span class="count">
          {% set views = 1 %}
          {% if report.class_counts and report.class_counts|length > 0 %}{% set views = views + 1 %}{% endif %}
          {% if report.split_counts and report.split_counts|length > 0 %}{% set views = views + 1 %}{% endif %}
          {{ views }} views
        </span>
        <span class="chev">⌄</span>
      </summary>
      <div class="section-body">
        {% if report.class_counts and report.class_counts|length > 0 %}
        <div class="graph-wrap">
          <div class="dist-head">
            <div class="graph-title">Class distribution</div>

            <div class="view-toggle" aria-label="Distribution view toggle">
              <button type="button" class="active distribution-graph-btn" onclick="setDistributionView('graph')">
                Graph
              </button>
              <button type="button" class="distribution-json-btn" onclick="setDistributionView('json')">
                JSON
              </button>
            </div>
          </div>

          {% set sorted_classes = report.class_counts|dictsort %}
          {% set graph_max = report.class_counts.values() | max %}
          {% set class_bar_w = 42 %}
          {% set class_gap = 18 %}
          {% set class_chart_w = 120 + ((sorted_classes|length) * (class_bar_w + class_gap)) + 60 %}

          <div id="classGraphView" class="class-view active">
            <div class="svg-card" style="margin-top: 10px;">
              <div class="chart-scroller">
                <svg class="chart-svg" viewBox="0 0 {{ class_chart_w }} 340" width="{{ class_chart_w }}" height="340" role="img" aria-label="Class distribution vertical bar chart">
                  <defs>
                    <linearGradient id="verticalClassGradient" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="#60a5fa"></stop>
                      <stop offset="100%" stop-color="#818cf8"></stop>
                    </linearGradient>
                  </defs>

                  <line x1="80" y1="280" x2="{{ class_chart_w - 30 }}" y2="280" stroke="rgba(148,163,184,0.16)" stroke-width="1"></line>
                  <line x1="80" y1="210" x2="{{ class_chart_w - 30 }}" y2="210" stroke="rgba(148,163,184,0.08)" stroke-width="1"></line>
                  <line x1="80" y1="140" x2="{{ class_chart_w - 30 }}" y2="140" stroke="rgba(148,163,184,0.08)" stroke-width="1"></line>
                  <line x1="80" y1="70" x2="{{ class_chart_w - 30 }}" y2="70" stroke="rgba(148,163,184,0.08)" stroke-width="1"></line>

                  {% set class_left = 100 %}
                  {% set class_max_h = 190 %}

                  {% for label, count in sorted_classes %}
                    {% set x = class_left + (loop.index0 * (class_bar_w + class_gap)) %}
                    {% set h = (count / graph_max) * class_max_h %}
                    {% set y = 280 - h %}
                    {% set short_label = label[:10] ~ ('…' if label|length > 10 else '') %}

                    <g>
                      <title>{{ label }}: {{ count }}</title>
                      <rect x="{{ x }}" y="{{ y }}" width="{{ class_bar_w }}" height="{{ h }}" rx="10" fill="url(#verticalClassGradient)"></rect>

                      <text x="{{ x + (class_bar_w / 2) }}" y="{{ y - 8 }}" text-anchor="middle"
                            fill="#e7edf7" font-size="11" font-family="Inter, sans-serif" font-weight="700">
                        {{ count }}
                      </text>

                      <text x="{{ x + (class_bar_w / 2) }}" y="305" text-anchor="middle"
                            fill="#94a3b8" font-size="10" font-family="Inter, sans-serif">
                        {{ short_label }}
                      </text>
                    </g>
                  {% endfor %}
                </svg>
              </div>
            </div>
          </div>

          <div id="classJsonView" class="class-view">
            <div class="code-wrap">
              <button type="button" class="copy-btn" onclick="copyCode(this)">Copy</button>
              <pre class="code-block">{{ report.class_counts | tojson(indent=2) }}</pre>
            </div>
          </div>
        </div>
        {% endif %}

        {% if report.split_counts and report.split_counts|length > 0 %}
        <div class="graph-wrap">
          <div class="dist-head">
            <div class="graph-title" style="margin-top: 12px;">Split distribution</div>

            <div class="view-toggle" aria-label="Distribution view toggle">
              <button type="button" class="active distribution-graph-btn" onclick="setDistributionView('graph')">
                Graph
              </button>
              <button type="button" class="distribution-json-btn" onclick="setDistributionView('json')">
                JSON
              </button>
            </div>
          </div>

          {% set sorted_splits = report.split_counts|dictsort %}
          {% set max_split = report.split_counts.values() | max %}
          {% set split_bar_w = 84 %}
          {% set split_gap = 34 %}
          {% set split_chart_w = 120 + ((sorted_splits|length) * (split_bar_w + split_gap)) + 60 %}

          <div id="splitGraphView" class="split-view active">
            <div class="svg-card">
              <div class="chart-scroller">
                <svg class="chart-svg" viewBox="0 0 {{ split_chart_w }} 340" width="{{ split_chart_w }}" height="340" role="img" aria-label="Split distribution vertical bar chart">
                  <defs>
                    <linearGradient id="splitVerticalGradient" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%" stop-color="#93c5fd"></stop>
                      <stop offset="100%" stop-color="#60a5fa"></stop>
                    </linearGradient>
                  </defs>

                  <line x1="80" y1="280" x2="{{ split_chart_w - 30 }}" y2="280" stroke="rgba(148,163,184,0.16)" stroke-width="1"></line>
                  <line x1="80" y1="210" x2="{{ split_chart_w - 30 }}" y2="210" stroke="rgba(148,163,184,0.08)" stroke-width="1"></line>
                  <line x1="80" y1="140" x2="{{ split_chart_w - 30 }}" y2="140" stroke="rgba(148,163,184,0.08)" stroke-width="1"></line>
                  <line x1="80" y1="70" x2="{{ split_chart_w - 30 }}" y2="70" stroke="rgba(148,163,184,0.08)" stroke-width="1"></line>

                  {% set split_left = 100 %}
                  {% set split_max_h = 190 %}

                  {% for split, count in sorted_splits %}
                    {% set x = split_left + (loop.index0 * (split_bar_w + split_gap)) %}
                    {% set h = (count / max_split) * split_max_h %}
                    {% set y = 280 - h %}

                    <g>
                      <title>{{ split }}: {{ count }}</title>
                      <rect x="{{ x }}" y="{{ y }}" width="{{ split_bar_w }}" height="{{ h }}" rx="10" fill="url(#splitVerticalGradient)"></rect>

                      <text x="{{ x + (split_bar_w / 2) }}" y="{{ y - 8 }}" text-anchor="middle"
                            fill="#e7edf7" font-size="11" font-family="Inter, sans-serif" font-weight="700">
                        {{ count }}
                      </text>

                      <text x="{{ x + (split_bar_w / 2) }}" y="305" text-anchor="middle"
                            fill="#94a3b8" font-size="11" font-family="Inter, sans-serif">
                        {{ split }}
                      </text>
                    </g>
                  {% endfor %}
                </svg>
              </div>
            </div>
          </div>

          <div id="splitJsonView" class="split-view">
            <div class="code-wrap">
              <button type="button" class="copy-btn" onclick="copyCode(this)">Copy</button>
              <pre class="code-block">{{ report.split_counts | tojson(indent=2) }}</pre>
            </div>
          </div>
        </div>
        {% endif %}
      </div>
    </details>

    <details class="section" id="priorities" open>
      <summary class="section-head">
        <div>
          <div class="head-title">What to fix first</div>
          <div class="head-sub">A short prioritized list of non-OK findings</div>
        </div>
        <span class="count">{{ ns.warning + ns.error }}</span>
        <span class="chev">⌄</span>
      </summary>
      <div class="section-body">
        <div class="priority-list">
          {% set issue_ns = namespace(count=0) %}
          {% for c in report.checks %}
            {% if c.status != 'ok' %}
              {% set issue_ns.count = issue_ns.count + 1 %}
              <div class="priority-item {{ c.status }}">
                <div class="priority-top">
                  <strong>{{ c.name }}</strong>
                  <span class="badge badge-{{ c.status }}">{{ c.status }}</span>
                </div>
                <div class="muted">{{ c.summary }}</div>
                {% if c.suggestions %}
                <ul class="suggest">
                  {% for s in c.suggestions[:4] %}
                  <li>{{ s }}</li>
                  {% endfor %}
                </ul>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}

          {% if issue_ns.count == 0 %}
          <div class="priority-item">
            <div class="priority-top">
              <strong>No immediate fixes needed</strong>
              <span class="badge badge-ok">ok</span>
            </div>
            <div class="muted">All checks are currently OK.</div>
          </div>
          {% endif %}
        </div>
      </div>
    </details>

    <details class="section" id="checks" open>
      <summary class="section-head">
        <div>
          <div class="head-title">Checks</div>
          <div class="head-sub">Structured details, long values, groups, pairs, and suggestions</div>
        </div>
        <span class="count">{{ report.checks | length }}</span>
        <span class="chev">⌄</span>
      </summary>
      <div class="section-body">
        <div class="checks-wrap">
          {% for c in report.checks %}
          <details class="check" {% if c.status != 'ok' %}open{% endif %}>
            <summary class="check-head">
              <div>
                <div class="head-title">{{ c.name }}</div>
                <div class="head-sub">{{ c.summary }}</div>
              </div>
              <span class="badge badge-{{ c.status }}">{{ c.status }}</span>
              <span class="chev">⌄</span>
            </summary>
            <div class="check-body">
              {% if c.suggestions %}
              <div class="detail-box" style="margin-top: 10px;">
                <div class="label">Suggestions</div>
                <ul class="suggest">
                  {% for s in c.suggestions %}
                  <li>{{ s }}</li>
                  {% endfor %}
                </ul>
              </div>
              {% endif %}

              {% if c.details %}
              <div class="detail-grid">
                {% for key, value in c.details.items() %}
                  {% if key != 'candidates' and key != 'groups' and key != 'pair_examples' %}
                  <div class="detail-box">
                    <div class="label">{{ key | replace('_', ' ') }}</div>
                    {% if value is mapping %}
                      <div class="code-wrap">
                        <button type="button" class="copy-btn" onclick="copyCode(this)">Copy</button>
                        <pre class="code-block">{{ value | tojson(indent=2) }}</pre>
                      </div>
                    {% elif value is sequence and value is not string %}
                      {% if value|length > 0 and value|length <= 8 %}
                        <div class="chips">
                          {% for item in value %}
                          <span class="chip">{{ item }}</span>
                          {% endfor %}
                        </div>
                      {% else %}
                        <div class="code-wrap">
                          <button type="button" class="copy-btn" onclick="copyCode(this)">Copy</button>
                          <pre class="code-block">{{ value | tojson(indent=2) }}</pre>
                        </div>
                      {% endif %}
                    {% else %}
                      <div class="value">{{ value }}</div>
                    {% endif %}
                  </div>
                  {% endif %}
                {% endfor %}
              </div>
              {% endif %}

              {% if c.name == 'label_hints' and c.details and c.details.candidates %}
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Sample</th>
                      <th>Current label</th>
                      <th>Suspected label</th>
                      <th>Score</th>
                      <th>Reason</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for cand in c.details.candidates[:10] %}
                    <tr>
                      <td><strong>{{ cand.sample_id }}</strong></td>
                      <td>{{ cand.current_label }}</td>
                      <td>{{ cand.suspected_label }}</td>
                      <td>{{ cand.score }}</td>
                      <td class="muted">{{ cand.reason }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              {% endif %}

              {% if c.name != 'label_hints' and c.details and c.details.groups %}
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Group</th>
                      <th>Members</th>
                      <th>Count</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for group in c.details.groups[:10] %}
                    <tr>
                      <td><strong>#{{ loop.index }}</strong></td>
                      <td class="muted">{{ group | join(', ') }}</td>
                      <td>{{ group | length }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              {% endif %}

              {% if c.details and c.details.pair_examples %}
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>A</th>
                      <th>B</th>
                      <th>Distance</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for pair in c.details.pair_examples[:12] %}
                    <tr>
                      <td class="muted">{{ pair.id_a }}</td>
                      <td class="muted">{{ pair.id_b }}</td>
                      <td>{{ pair.distance }}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
              {% endif %}
            </div>
          </details>
          {% endfor %}
        </div>
      </div>
    </details>

    <footer>Generated by MLSanity • minimal dark report</footer>
  </div>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MLSanity — Dataset report</title>
  <style>
    :root {
      --bg: #0f1419;
      --card: #1a2332;
      --text: #e7ecf3;
      --muted: #8b9bb4;
      --ok: #3ecf8e;
      --warn: #f5a623;
      --err: #ff6b6b;
      --accent: #5b8def;
    }
    * { box-sizing: border-box; }
    body {
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      padding: 2rem 1.5rem 4rem;
      line-height: 1.5;
    }
    .wrap { max-width: 900px; margin: 0 auto; }
    h1 { font-size: 1.75rem; font-weight: 650; margin: 0 0 0.25rem; letter-spacing: -0.02em; }
    .sub { color: var(--muted); font-size: 0.95rem; margin-bottom: 1.75rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat {
      background: var(--card);
      border-radius: 10px;
      padding: 1rem 1.1rem;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .stat label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 0.35rem; }
    .stat val { font-size: 1.35rem; font-weight: 600; }
    .score-healthy { color: var(--ok); }
    .score-acceptable { color: #a8d5ff; }
    .score-needs_attention { color: var(--warn); }
    .score-critical { color: var(--err); }
    h2 { font-size: 1.1rem; margin: 2rem 0 1rem; color: var(--accent); font-weight: 600; }
    .check {
      background: var(--card);
      border-radius: 10px;
      padding: 1rem 1.15rem;
      margin-bottom: 0.75rem;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .check-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem 1rem; margin-bottom: 0.5rem; }
    .name { font-weight: 600; }
    .badge {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 0.2rem 0.5rem;
      border-radius: 6px;
    }
    .badge-ok { background: rgba(62, 207, 142, 0.15); color: var(--ok); }
    .badge-warning { background: rgba(245, 166, 35, 0.15); color: var(--warn); }
    .badge-error { background: rgba(255, 107, 107, 0.15); color: var(--err); }
    .summary { color: var(--muted); font-size: 0.95rem; }
    ul.suggest { margin: 0.5rem 0 0 1.1rem; color: var(--muted); font-size: 0.9rem; }
    footer { margin-top: 3rem; font-size: 0.8rem; color: var(--muted); }
    a { color: var(--accent); }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>MLSanity <e>dataset report</e></h1>
    <p class="sub">Sanity-check your dataset before training your model.</p>

    <div class="grid">
      <div class="stat">
        <label>Dataset type</label>
        <val>{{ report.dataset_type }}</val>
      </div>
      <div class="stat">
        <label>Total samples</label>
        <val>{{ report.total_samples }}</val>
      </div>
      <div class="stat">
        <label>Health score</label>
        <val class="score-{{ report.overall_status }}">{{ report.health_score }}/100</val>
      </div>
      <div class="stat">
        <label>Overall status</label>
        <val>{{ report.overall_status }}</val>
      </div>
    </div>

    {% if report.dataset_path %}
    <p class="sub" style="margin-top:-1rem;"><strong>Path:</strong> {{ report.dataset_path }}</p>
    {% endif %}

    <h2>Checks</h2>
    {% for c in report.checks %}
    <div class="check">
      <div class="check-head">
        <span class="name">{{ c.name }}</span>
        <span class="badge badge-{{ c.status }}">{{ c.status }}</span>
      </div>
      <div class="summary">{{ c.summary }}</div>
      {% if c.suggestions %}
      <ul class="suggest">
        {% for s in c.suggestions %}
        <li>{{ s }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}

    <footer>Generated by MLSanity v0.1</footer>
  </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>MLSanity — Dataset report</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { colors: { primary: '#3b82f6', success: '#22c55e', warning: '#eab308', error: '#ef4444', darkBg: '#0f172a', darkCard: '#1e293b', darkBorder: '#334155' } } }
    }
  </script>
  
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/gridjs/dist/theme/mermaid.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/gridjs/dist/gridjs.umd.js"></script>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-darkBg dark:text-gray-100 font-sans transition-colors duration-200">
  
  <header class="sticky top-0 z-50 border-b border-gray-200 dark:border-darkBorder bg-white/80 dark:bg-darkCard/80 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
      <div class="flex items-center gap-3 font-bold text-sm tracking-tight">
        <div class="w-7 h-7 rounded-md bg-primary text-white flex items-center justify-center">⚡</div>
        <span>MLSanity</span>
      </div>
      <nav class="flex items-center gap-1">
        <button class="nav-btn active px-3 py-1.5 rounded-lg text-sm font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 transition" data-target="overviewPage">Overview</button>
        <button class="nav-btn px-3 py-1.5 rounded-lg text-sm font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 transition" data-target="distributionPage">Distribution</button>
        <button class="nav-btn px-3 py-1.5 rounded-lg text-sm font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-800 transition" data-target="checksPage">Checks</button>
      </nav>
      <button id="themeToggle" class="p-2 rounded-lg bg-gray-200 dark:bg-slate-800 text-gray-600 dark:text-gray-300 text-xs font-bold">Toggle Mode</button>
    </div>
  </header>

  {% set ns = namespace(ok=0, warning=0, error=0) %}
  {% for c in report.checks %}
    {% if c.status == 'ok' %}{% set ns.ok = ns.ok + 1 %}
    {% elif c.status == 'warning' %}{% set ns.warning = ns.warning + 1 %}
    {% elif c.status == 'error' %}{% set ns.error = ns.error + 1 %}{% endif %}
  {% endfor %}
  {% set total_checks = (report.checks|length) if report.checks|length else 1 %}

  <main class="max-w-7xl mx-auto px-4 py-8">
    <section id="overviewPage" class="page-view block space-y-6">
      
      <div class="p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-2xl font-bold">Dataset Report</h1>
          <div class="text-xs text-gray-500 mt-1 flex items-center gap-2">
            <span class="uppercase tracking-wider font-semibold text-gray-700 dark:text-gray-300">{{ report.dataset_type }}</span> &bull; 
            <span>{{ report.total_samples }} samples</span> &bull;
            <span id="generatedAt"></span>
          </div>
        </div>
        <span class="px-3 py-1 text-xs font-bold rounded-full uppercase border 
          {% if report.overall_status in ['healthy', 'ok'] %} bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-400 dark:border-green-800
          {% elif report.overall_status in ['acceptable', 'warning', 'needs_attention'] %} bg-yellow-100 text-yellow-700 border-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-400 dark:border-yellow-800
          {% else %} bg-red-100 text-red-700 border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-800 {% endif %}">
          {{ report.overall_status|replace('_', ' ') }}
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        <div class="col-span-1 md:col-span-4 p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm flex flex-col items-center justify-center min-h-[260px]">
          <div class="relative w-40 h-40 flex items-center justify-center">
            <svg class="absolute inset-0 w-full h-full transform -rotate-90" viewBox="0 0 100 100">
              <circle cx="50" cy="50" r="40" fill="none" class="stroke-gray-200 dark:stroke-slate-700" stroke-width="8" />
              <circle cx="50" cy="50" r="40" fill="none" stroke="{% if report.health_score >= 85 %}#22c55e{% elif report.health_score >= 60 %}#eab308{% else %}#ef4444{% endif %}" stroke-width="8" stroke-dasharray="251.2" stroke-dashoffset="{{ 251.2 - (251.2 * report.health_score / 100) }}" class="transition-all duration-1000 ease-out" />
            </svg>
            <div class="text-center mt-2">
              <div class="text-4xl font-extrabold">{{ report.health_score }}</div>
              <div class="text-xs text-gray-500">/ 100</div>
            </div>
          </div>
        </div>

        <div class="col-span-1 md:col-span-8 grid grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="p-4 border border-gray-200 dark:border-darkBorder bg-gray-50 dark:bg-slate-800/50 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Total Checks</div>
            <div class="text-2xl font-bold">{{ report.checks|length }}</div>
          </div>
          <div class="p-4 border border-gray-200 dark:border-darkBorder bg-gray-50 dark:bg-slate-800/50 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Passed</div>
            <div class="text-2xl font-bold text-success">{{ ns.ok }}</div>
          </div>
          <div class="p-4 border border-gray-200 dark:border-darkBorder bg-gray-50 dark:bg-slate-800/50 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Warnings</div>
            <div class="text-2xl font-bold text-warning">{{ ns.warning }}</div>
          </div>
          <div class="p-4 border border-gray-200 dark:border-darkBorder bg-gray-50 dark:bg-slate-800/50 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Errors</div>
            <div class="text-2xl font-bold text-error">{{ ns.error }}</div>
          </div>
          <div class="p-4 border border-gray-200 dark:border-darkBorder bg-gray-50 dark:bg-slate-800/50 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Pass Rate</div>
            <div class="text-2xl font-bold text-success">{{ ((ns.ok / total_checks) * 100)|round(1) }}%</div>
          </div>
          <div class="p-4 border border-gray-200 dark:border-darkBorder bg-gray-50 dark:bg-slate-800/50 rounded-lg">
            <div class="text-xs text-gray-500 mb-1">Issue Rate</div>
            <div class="text-2xl font-bold text-error">{{ (((ns.warning + ns.error) / total_checks) * 100)|round(1) }}%</div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="col-span-2 p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-lg">What to Fix First</h3>
            <button onclick="downloadCSV()" class="px-3 py-1.5 text-xs bg-gray-200 dark:bg-slate-800 hover:bg-gray-300 dark:hover:bg-slate-700 rounded-md font-semibold transition">Export Issues to CSV</button>
          </div>
          <div class="space-y-3">
            {% set has_fix = namespace(v=false) %}
            {% for c in report.checks if c.status != 'ok' %}
              {% set has_fix.v = true %}
              <div class="p-4 border border-gray-200 dark:border-darkBorder bg-gray-50 dark:bg-slate-800/30 rounded-lg transition hover:shadow-md">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2 py-0.5 text-[10px] font-bold rounded-md uppercase 
                    {% if c.status == 'warning' %}bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400
                    {% else %}bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400{% endif %}">{{ c.status }}</span>
                  <span class="font-semibold text-sm capitalize">{{ c.name|replace('_', ' ') }}</span>
                </div>
                <div class="text-xs text-gray-600 dark:text-gray-400 mb-2">{{ c.summary }}</div>
                {% if c.suggestions and c.suggestions|length > 0 %}
                  <div class="text-[11px] text-primary font-medium">&rarr; {{ c.suggestions[0] }}</div>
                {% endif %}
              </div>
            {% endfor %}
            {% if not has_fix.v %}
              <div class="text-sm text-gray-500 italic">No immediate fixes needed. Dataset looks healthy!</div>
            {% endif %}
          </div>
        </div>
        
        <div class="col-span-1 p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm">
          <h3 class="font-bold text-lg mb-4">Issue Distribution</h3>
          <div class="h-[250px] w-full flex items-center justify-center">
            <canvas id="issueChart"></canvas>
          </div>
        </div>
      </div>

    </section>

    <section id="distributionPage" class="page-view hidden space-y-6">
      
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-bold">Data Distribution</h2>
        <div class="flex bg-gray-100 dark:bg-slate-800 p-1 rounded-lg">
          <button class="dist-btn active px-3 py-1 text-xs font-semibold rounded-md" data-view="graph" onclick="toggleDistView('graph')">Graph</button>
          <button class="dist-btn px-3 py-1 text-xs font-semibold rounded-md text-gray-500" data-view="json" onclick="toggleDistView('json')">JSON</button>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-6">
        <div class="p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-bold">Class Distribution</h3>
            <span class="text-xs font-medium text-gray-500 bg-gray-100 dark:bg-slate-800 px-2 py-1 rounded">{{ report.class_counts|length }} classes</span>
          </div>
          {% if report.class_counts %}
            <div id="classGraphView" class="dist-pane block">
               <div class="w-full overflow-x-auto h-[350px]">
                 <div class="min-w-[600px] h-full relative">
                   <canvas id="classChart"></canvas>
                 </div>
               </div>
            </div>
            <div id="classJsonView" class="dist-pane hidden relative">
              <button onclick="navigator.clipboard.writeText(this.nextElementSibling.innerText)" class="absolute top-2 right-2 px-2 py-1 bg-gray-200 dark:bg-slate-700 rounded text-xs">Copy</button>
              <pre class="bg-gray-50 dark:bg-slate-900 p-4 rounded-lg border border-gray-200 dark:border-darkBorder text-xs overflow-auto max-h-[300px] text-gray-800 dark:text-gray-300">{{ report.class_counts|tojson(indent=2) }}</pre>
            </div>
          {% else %}
            <div class="text-sm text-gray-500">No class documentation available.</div>
          {% endif %}
        </div>
        
        <div class="p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm">
          <div class="flex justify-between items-center mb-4">
            <h3 class="font-bold">Split Distribution</h3>
            <span class="text-xs font-medium text-gray-500 bg-gray-100 dark:bg-slate-800 px-2 py-1 rounded">{{ report.split_counts|length }} splits</span>
          </div>
          {% if report.split_counts %}
            <div id="splitGraphView" class="dist-pane block">
               <div class="w-full h-[250px]">
                 <canvas id="splitChart"></canvas>
               </div>
            </div>
            <div id="splitJsonView" class="dist-pane hidden relative">
              <button onclick="navigator.clipboard.writeText(this.nextElementSibling.innerText)" class="absolute top-2 right-2 px-2 py-1 bg-gray-200 dark:bg-slate-700 rounded text-xs">Copy</button>
              <pre class="bg-gray-50 dark:bg-slate-900 p-4 rounded-lg border border-gray-200 dark:border-darkBorder text-xs overflow-auto max-h-[300px] text-gray-800 dark:text-gray-300">{{ report.split_counts|tojson(indent=2) }}</pre>
            </div>
          {% else %}
            <div class="text-sm text-gray-500">No split documentation available.</div>
          {% endif %}
        </div>
      </div>
    </section>

    <section id="checksPage" class="page-view hidden space-y-6">
      
      <div class="overflow-x-auto pb-2">
        <div class="inline-flex gap-2 p-1 bg-gray-100 dark:bg-slate-800 rounded-lg">
          {% for c in report.checks %}
            <button class="check-tab-btn flex items-center gap-2 px-3 py-2 text-xs font-semibold rounded-md whitespace-nowrap transition {% if loop.first %}bg-white dark:bg-darkBorder shadow-sm text-primary{% else %}text-gray-600 dark:text-gray-400{% endif %}" data-target="panel-{{ loop.index0 }}" onclick="openCheck('panel-{{ loop.index0 }}', this)">
              <span class="w-2 h-2 rounded-full {% if c.status=='ok' %}bg-success{% elif c.status=='warning' %}bg-warning{% else %}bg-error{% endif %}"></span>
              {{ c.name }}
            </button>
          {% endfor %}
        </div>
      </div>

      {% for c in report.checks %}
        <div id="panel-{{ loop.index0 }}" class="check-panel {% if loop.first %}block{% else %}hidden{% endif %} space-y-6">
          <div class="p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="text-lg font-bold capitalize">{{ c.name|replace('_', ' ') }}</h3>
              <span class="px-2 py-0.5 text-xs font-bold rounded-full uppercase border 
                  {% if c.status == 'ok' %} bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-400 dark:border-green-800
                  {% elif c.status == 'warning' %} bg-yellow-100 text-yellow-700 border-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-400 dark:border-yellow-800
                  {% else %} bg-red-100 text-red-700 border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-800 {% endif %}">
                  {{ c.status }}
              </span>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-400">{{ c.summary }}</p>
            {% if c.suggestions %}
              <div class="mt-4 pt-3 border-t border-gray-100 dark:border-darkBorder space-y-1">
                <div class="text-xs uppercase font-bold text-gray-400 mb-2">Suggestions</div>
                {% for s in c.suggestions %}
                  <div class="text-xs text-primary font-medium">&rarr; {{ s }}</div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
          
          {% if c.name == 'label_hints' and c.details and c.details.candidates %}
            <div class="p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm overflow-hidden">
              <h3 class="font-bold mb-4">Suspicious Samples</h3>
              <div id="gridjs-wrapper-{{ loop.index0 }}" class="w-full text-sm"></div>
            </div>
          {% endif %}

          {% if c.details %}
            <div class="p-5 border border-gray-200 dark:border-darkBorder bg-white dark:bg-darkCard rounded-xl shadow-sm relative">
              <h3 class="font-bold mb-4 text-sm uppercase tracking-wider text-gray-500">Raw Details</h3>
              <button onclick="navigator.clipboard.writeText(this.nextElementSibling.innerText)" class="absolute top-5 right-5 px-3 py-1 bg-gray-200 dark:bg-slate-700 hover:bg-gray-300 dark:hover:bg-slate-600 transition rounded text-xs font-semibold">Copy JSON</button>
              <pre class="bg-gray-50 dark:bg-slate-900 p-4 rounded-lg border border-gray-200 dark:border-darkBorder text-xs overflow-auto max-h-[400px] text-gray-800 dark:text-gray-300">{{ c.details|tojson(indent=2) }}</pre>
            </div>
          {% endif %}
        </div>
      {% endfor %}

    </section>
  </main>

  <script>
    // Tab tracking
    document.querySelectorAll('.nav-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.nav-btn').forEach(b => {
          b.classList.remove('active', 'text-primary', 'bg-white', 'dark:bg-slate-800', 'shadow-sm');
          b.classList.add('text-gray-600', 'hover:bg-gray-100');
        });
        btn.classList.remove('text-gray-600', 'hover:bg-gray-100');
        btn.classList.add('active', 'text-primary', 'bg-white', 'dark:bg-slate-800', 'shadow-sm');
        
        document.querySelectorAll('.page-view').forEach(p => p.classList.add('hidden'));
        document.getElementById(btn.dataset.target).classList.remove('hidden');
      });
    });

    // Dark mode toggle
    const themeToggle = document.getElementById('themeToggle');
    const htmlElem = document.documentElement;
    themeToggle.addEventListener('click', () => {
      htmlElem.classList.toggle('dark');
      Chart.helpers.each(Chart.instances, function(instance){
        instance.options.color = htmlElem.classList.contains('dark') ? '#cbd5e1' : '#475569';
        instance.update();
      });
    });

    // Sub-tab toggling for Distribution
    window.toggleDistView = function(view) {
      document.querySelectorAll('.dist-btn').forEach(b => {
        if(b.dataset.view === view) {
          b.classList.add('bg-white', 'dark:bg-darkCard', 'shadow-sm', 'text-gray-900', 'dark:text-white');
          b.classList.remove('text-gray-500');
        } else {
          b.classList.remove('bg-white', 'dark:bg-darkCard', 'shadow-sm', 'text-gray-900', 'dark:text-white');
          b.classList.add('text-gray-500');
        }
      });
      document.querySelectorAll('.dist-pane').forEach(p => p.classList.add('hidden'));
      document.getElementById('class' + view.charAt(0).toUpperCase() + view.slice(1) + 'View').classList.remove('hidden');
      if (document.getElementById('split' + view.charAt(0).toUpperCase() + view.slice(1) + 'View')) {
        document.getElementById('split' + view.charAt(0).toUpperCase() + view.slice(1) + 'View').classList.remove('hidden');
      }
    };

    // Sub-tab toggling for Checks
    window.openCheck = function(target, el) {
      document.querySelectorAll('.check-tab-btn').forEach(b => {
        b.classList.remove('bg-white', 'dark:bg-darkBorder', 'shadow-sm', 'text-primary');
        b.classList.add('text-gray-600', 'dark:text-gray-400');
      });
      el.classList.add('bg-white', 'dark:bg-darkBorder', 'shadow-sm', 'text-primary');
      el.classList.remove('text-gray-600', 'dark:text-gray-400');
      document.querySelectorAll('.check-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(target).classList.remove('hidden');
    };

    // Chart.js integrations
    document.addEventListener("DOMContentLoaded", () => {
      const textColor = document.documentElement.classList.contains('dark') ? '#cbd5e1' : '#475569';
      Chart.defaults.color = textColor;
      Chart.defaults.font.family = 'Inter, system-ui, sans-serif';

      // 1. Issue Distribution Chart
      const issueCtx = document.getElementById('issueChart');
      if (issueCtx) {
        new Chart(issueCtx, {
          type: 'doughnut',
          data: {
            labels: ['Passed', 'Warnings', 'Errors'],
            datasets: [{
              data: [{{ ns.ok }}, {{ ns.warning }}, {{ ns.error }}],
              backgroundColor: ['#22c55e', '#eab308', '#ef4444'],
              borderWidth: 0,
              hoverOffset: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } },
            cutout: '75%'
          }
        });
      }

      // 2. Class Distribution
      const classDataRaw = {{ report.class_counts|default({})|tojson(indent=2) }};
      const classLabels = Object.keys(classDataRaw);
      const classValues = Object.values(classDataRaw);
      const classCtx = document.getElementById('classChart');
      if (classCtx && classLabels.length > 0) {
        new Chart(classCtx, {
          type: 'bar',
          data: {
            labels: classLabels,
            datasets: [{
              label: 'Samples',
              data: classValues,
              backgroundColor: '#3b82f6',
              borderRadius: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, grid: { color: 'rgba(156, 163, 175, 0.1)' } },
              x: { grid: { display: false } }
            }
          }
        });
      }

      // 3. Split Distribution
      const splitDataRaw = {{ report.split_counts|default({})|tojson(indent=2) }};
      const splitLabels = Object.keys(splitDataRaw);
      const splitValues = Object.values(splitDataRaw);
      const splitCtx = document.getElementById('splitChart');
      if (splitCtx && splitLabels.length > 0) {
        new Chart(splitCtx, {
          type: 'bar',
          data: {
            labels: splitLabels,
            datasets: [{
              label: 'Samples',
              data: splitValues,
              backgroundColor: '#22c55e',
              borderRadius: 4
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true, grid: { color: 'rgba(156, 163, 175, 0.1)' } },
              x: { grid: { display: false } }
            }
          }
        });
      }

      // 4. Grid.js for tables
      {% for c in report.checks %}
        {% if c.name == 'label_hints' and c.details and c.details.candidates %}
          const tableData{{ loop.index0 }} = [
            {% for cand in c.details.candidates %}
              ["{{ cand.sample_id }}", "{{ cand.current_label }}", "{{ cand.suspected_label }}", {{ cand.score|round(3) }}, "{{ cand.reason }}"],
            {% endfor %}
          ];
          new gridjs.Grid({
            columns: ["Sample ID", "Current Label", "Suspected Label", "Score", "Reason"],
            data: tableData{{ loop.index0 }},
            sort: true,
            search: true,
            pagination: { enabled: true, limit: 10 },
            className: {
               table: 'w-full !border-0',
               th: 'bg-gray-50 dark:bg-slate-800 text-xs text-gray-500 uppercase font-semibold border-b',
               td: 'text-xs text-gray-700 dark:text-gray-300 border-b dark:border-darkBorder p-3'
            }
          }).render(document.getElementById("gridjs-wrapper-{{ loop.index0 }}"));
        {% endif %}
      {% endfor %}
      
      const genAt = document.getElementById("generatedAt");
      if(genAt) genAt.innerText = new Date().toLocaleString();
    });

    window.downloadCSV = function() {
      const rows = [["Check", "Status", "Summary", "Suggestions"]];
      {% for c in report.checks if c.status != 'ok' %}
        rows.push([
          "{{ c.name }}", 
          "{{ c.status }}", 
          "{{ c.summary }}", 
          "{% if c.suggestions %}{{ c.suggestions[0] }}{% endif %}"
        ]);
      {% endfor %}
      let csvContent = "data:text/csv;charset=utf-8," 
        + rows.map(e => e.map(cell => '"' + cell.replace(/"/g, '""') + '"').join(",")).join("\n");
      var encodedUri = encodeURI(csvContent);
      var link = document.createElement("a");
      link.setAttribute("href", encodedUri);
      link.setAttribute("download", "mlsanity_issues.csv");
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    };
  </script>
</body>
</html>